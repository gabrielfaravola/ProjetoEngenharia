```plantuml

@startuml
skinparam actorStyle awesome
left to right direction

actor "Cidadão / Usuário" as User
actor "Sistema de IA (Python)" as IA << System >>
actor "Fontes Externas" as API << Service >>

package "Plataforma Transparência Política" {
    usecase "Listar Candidatos (Ano X)" as UC1
    usecase "Visualizar Detalhes do Candidato" as UC2
    usecase "Consultar Plano de Governo Simplificado" as UC3
    usecase "Acessar Clipping e Resumo de Mídias" as UC4
    usecase "Ver Monitoramento de Redes Sociais" as UC5
    usecase "Analisar Coerência (Geral e por Tópico)" as UC6
    usecase "Visualizar Espectro Político" as UC7
    
    usecase "Processar Linguagem Natural (Resumos)" as UC_IA1
    usecase "Calcular Índices de Coerência" as UC_IA2
    usecase "Coletar Dados (APIs/Web Scraping)" as UC_Data
}

' Relacionamentos do Usuário
User --> UC1
User --> UC2
UC2 ..> UC3 : <<extend>>
UC2 ..> UC4 : <<extend>>
UC2 ..> UC5 : <<extend>>
UC2 ..> UC6 : <<extend>>
UC2 ..> UC7 : <<extend>>

' Relacionamentos do Sistema de IA e APIs
UC3 <-- IA : "Gera resumos simplificados"
UC4 <-- IA : "Sintetiza vídeos/debates"
UC5 <-- IA : "Consolida temas recorrentes"
UC6 <-- IA : "Cruza dados e gera métricas"

IA --> UC_IA1
IA --> UC_IA2
IA --> UC_Data
UC_Data -- API : "Consome dados do TSE/Redes"

@enduml


